# ─── Server ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Amadeus API ──────────────────────────────────────────────────
# Get your free keys at: https://developers.amadeus.com/self-service
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
# Use 'test' for sandbox, 'production' for live
AMADEUS_HOSTNAME=test

# ─── JWT Auth ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
