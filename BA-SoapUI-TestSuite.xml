          <con:request name="GET Status BA117"
            URL="${#Project#BASE_URL}/flights/status?flightNumber=BA117"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Flight number BA117">
              <con:configuration><con:expression>$.data[0].flightNumber</con:expression><con:expectedContent>BA117</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Status on-time">
              <con:configuration><con:expression>$.data[0].status</con:expression><con:expectedContent>on-time</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Gate B22">
              <con:configuration><con:expression>$.data[0].gate</con:expression><con:expectedContent>B22</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Terminal 5">
              <con:configuration><con:expression>$.data[0].terminal</con:expression><con:expectedContent>5</con:expectedContent></con:configuration>
            </con:assertion>
