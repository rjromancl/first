import groovyx.net.http.RESTClient
def base = "https://first-eight-cyan.vercel.app/api"
def http = new RESTClient(base)
def resp = http.get(path: "/flights/search", query: [from:"LHR", to:"DXB", departureDate:"2026-10-18", adults:"1", cabin:"ECONOMY"])
assert resp.status == 200
def flight = resp.data.data.flights[0]
assert flight != null
testRunner.testCase.setPropertyValue("FLIGHT_OBJ", groovy.json.JsonOutput.toJson(flight))
testRunner.testCase.setPropertyValue("FLIGHT_NUM", flight.flightNumber)
log.info "E2E Step1 PASSED: Found flight ${flight.flightNumber} GBP${flight.price.grandTotal}"
        </con:script></con:config>
