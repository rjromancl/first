    <con:testCase name="TC4.6 Wrong Surname Returns 404" failOnError="false">
      <con:testStep type="httprequest" name="GET Wrong Surname">
        <con:config>
          <con:request name="GET Wrong Surname"
            URL="${#Project#BASE_URL}/bookings/XYMBA1?surname=WRONG"
