            <con:requestBody>{"checked":2,"cabin":1}</con:requestBody>
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Success true">
              <con:configuration><con:expression>$.success</con:expression><con:expectedContent>true</con:expectedContent></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC4.5 Invalid Reference Returns 404" failOnError="false">
      <con:testStep type="httprequest" name="GET Invalid Booking">
        <con:config>
          <con:request name="GET Invalid Booking"
            URL="${#Project#BASE_URL}/bookings/XXXXXX?surname=Smith"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 404">
              <con:configuration><con:codes>404</con:codes></con:configuration>
