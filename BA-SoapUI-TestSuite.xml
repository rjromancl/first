  <!-- ====================================================
       TEST SUITE 4: BOOKING LIFECYCLE
       ==================================================== -->
  <con:testSuite name="4 - Booking Lifecycle">
    <con:properties/>

    <con:testCase name="TC4.1 Create Booking" failOnError="true">
      <con:testStep type="httprequest" name="POST Create Booking">
        <con:config>
          <con:request name="POST Create Booking"
            URL="${#Project#BASE_URL}/bookings"
            method="POST" mediaType="application/json">
            <con:requestHeaders>
              <con:entry key="Content-Type" value="application/json"/>
            </con:requestHeaders>
            <con:requestBody>{"flightOffer":{"id":"1","flightNumber":"BA117","from":"LHR","to":"JFK","departure":"08:30","arrival":"11:45","duration":"7h 15m","stops":0,"aircraft":"777","date":"2026-12-20","prices":{"economy":349,"premiumEconomy":645,"businessClass":1256,"firstClass":2164},"price":{"grandTotal":"349","total":"349","currency":"GBP"},"numberOfStops":0,"itineraries":[{"duration":"PT7H15M","segments":[{"departure":{"iataCode":"LHR","at":"2026-12-20T08:30:00"},"arrival":{"iataCode":"JFK","at":"2026-12-20T11:45:00"},"carrierCode":"BA","number":"117","aircraft":{"code":"777"}}]}]},"travelers":[{"firstName":"John","lastName":"Smith","phone":"07912345678","nationality":"GB"}],"contacts":[]}</con:requestBody>
            <con:assertion type="Valid HTTP Status Codes" name="Status 200 or 201">
              <con:configuration><con:codes>200,201</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Success true">
              <con:configuration><con:expression>$.success</con:expression><con:expectedContent>true</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Status confirmed">
              <con:configuration><con:expression>$.data.status</con:expression><con:expectedContent>confirmed</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Exists" name="Reference exists">
              <con:configuration><con:expression>$.data.reference</con:expression></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC4.2 Retrieve Demo Booking XYMBA1" failOnError="true">
      <con:testStep type="httprequest" name="GET Booking XYMBA1">
        <con:config>
          <con:request name="GET Booking XYMBA1"
            URL="${#Project#BASE_URL}/bookings/XYMBA1?surname=Wilson"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Reference XYMBA1">
              <con:configuration><con:expression>$.data.reference</con:expression><con:expectedContent>XYMBA1</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Status confirmed">
              <con:configuration><con:expression>$.data.status</con:expression><con:expectedContent>confirmed</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Exists" name="Outbound flight">
              <con:configuration><con:expression>$.data.outbound.flightNumber</con:expression></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Origin LHR">
              <con:configuration><con:expression>$.data.outbound.from</con:expression><con:expectedContent>LHR</con:expectedContent></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC4.3 Select Seat on XYMBA1" failOnError="true">
      <con:testStep type="httprequest" name="PATCH Seat XYMBA1">
        <con:config>
          <con:request name="PATCH Seat XYMBA1"
            URL="${#Project#BASE_URL}/bookings/XYMBA1/seat"
            method="PATCH" mediaType="application/json">
            <con:requestHeaders>
              <con:entry key="Content-Type" value="application/json"/>
            </con:requestHeaders>
            <con:requestBody>{"seat":"14A","segment":"outbound"}</con:requestBody>
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Success true">
              <con:configuration><con:expression>$.success</con:expression><con:expectedContent>true</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Seat is 14A">
              <con:configuration><con:expression>$.data.seat</con:expression><con:expectedContent>14A</con:expectedContent></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC4.4 Update Baggage on XYMBA1" failOnError="true">
      <con:testStep type="httprequest" name="PATCH Bags XYMBA1">
        <con:config>
          <con:request name="PATCH Bags XYMBA1"
