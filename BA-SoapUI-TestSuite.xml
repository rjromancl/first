<?xml version="1.0" encoding="UTF-8"?>
<con:soapui-project
  xsi:schemaLocation="http://eviware.com/soapui/config soapui-config.xsd"
  xmlns:con="http://eviware.com/soapui/config"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  name="British Airways API Test Suite"
  resourceRoot=""
  activeEnvironment="Default"
  soapui-version="5.7.2">

  <!-- ═══════════════════════════════════════════
       PROJECT PROPERTIES
       BASE_URL: change to your deployment URL
       ═══════════════════════════════════════════ -->
  <con:properties>
    <con:property>
      <con:name>BASE_URL</con:name>
      <con:value>https://first-eight-cyan.vercel.app/api</con:value>
    </con:property>
  </con:properties>

  <!-- ═══════════════════════════════════════════
       REST SERVICE DEFINITION
       ═══════════════════════════════════════════ -->
  <con:interface xsi:type="con:RestService" name="BA Backend API"
    basePath="/api" type="rest">
    <con:endpoints>
      <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
    </con:endpoints>

    <!-- Health Resource -->
    <con:resource name="Health" path="/health" id="r-health">
      <con:method name="GET Health" id="m-health" method="GET">
        <con:response name="200" status="200" mediaType="application/json">
          <con:responseHeaders/>
        </con:response>
      </con:method>
    </con:resource>

    <!-- Flights Search Resource -->
    <con:resource name="Flights Search" path="/flights/search" id="r-flights-search">
      <con:method name="GET Search Flights" id="m-flights-search" method="GET">
        <con:parameters>
          <con:parameter name="from" default="LHR" style="QUERY"/>
          <con:parameter name="to" default="JFK" style="QUERY"/>
          <con:parameter name="departureDate" default="2026-12-20" style="QUERY"/>
          <con:parameter name="adults" default="1" style="QUERY"/>
          <con:parameter name="cabin" default="ECONOMY" style="QUERY"/>
        </con:parameters>
      </con:method>
    </con:resource>

    <!-- Flight Status Resource -->
    <con:resource name="Flight Status" path="/flights/status" id="r-flight-status">
      <con:method name="GET Flight Status" id="m-flight-status" method="GET">
        <con:parameters>
          <con:parameter name="flightNumber" default="BA117" style="QUERY"/>
        </con:parameters>
      </con:method>
    </con:resource>

    <!-- Airports Search Resource -->
    <con:resource name="Airports Search" path="/airports" id="r-airports">
      <con:method name="GET Airports" id="m-airports" method="GET">
        <con:parameters>
          <con:parameter name="q" default="london" style="QUERY"/>
        </con:parameters>
      </con:method>
    </con:resource>

    <!-- Destinations Resource -->
    <con:resource name="Destinations" path="/destinations" id="r-destinations">
      <con:method name="GET Destinations" id="m-destinations" method="GET"/>
    </con:resource>

    <!-- Bookings Resource -->
    <con:resource name="Bookings" path="/bookings" id="r-bookings">
      <con:method name="POST Create Booking" id="m-create-booking" method="POST">
        <con:request name="Request 1" mediaType="application/json">
          <con:requestHeaders>
            <con:entry key="Content-Type" value="application/json"/>
          </con:requestHeaders>
        </con:request>
      </con:method>
      <con:resource name="Booking by Reference" path="/{reference}" id="r-booking-ref">
        <con:parameters>
          <con:parameter name="reference" style="TEMPLATE" default="XYMBA1"/>
          <con:parameter name="surname" style="QUERY" default="Wilson"/>
        </con:parameters>
        <con:method name="GET Booking" id="m-get-booking" method="GET"/>
        <con:resource name="Seat" path="/seat" id="r-seat">
          <con:method name="PATCH Select Seat" id="m-select-seat" method="PATCH">
            <con:request name="Request 1" mediaType="application/json">
              <con:requestHeaders>
                <con:entry key="Content-Type" value="application/json"/>
              </con:requestHeaders>
            </con:request>
          </con:method>
        </con:resource>
        <con:resource name="Bags" path="/bags" id="r-bags">
          <con:method name="PATCH Update Bags" id="m-update-bags" method="PATCH">
            <con:request name="Request 1" mediaType="application/json">
              <con:requestHeaders>
                <con:entry key="Content-Type" value="application/json"/>
              </con:requestHeaders>
            </con:request>
          </con:method>
        </con:resource>
      </con:resource>
    </con:resource>

    <!-- Check-in Resource -->
    <con:resource name="Check-In" path="/checkin" id="r-checkin">
      <con:method name="POST Check-In" id="m-checkin" method="POST">
        <con:request name="Request 1" mediaType="application/json">
          <con:requestHeaders>
            <con:entry key="Content-Type" value="application/json"/>
          </con:requestHeaders>
        </con:request>
      </con:method>
    </con:resource>

    <!-- Avios Resource -->
    <con:resource name="Avios" path="/avios/calculate" id="r-avios">
      <con:method name="GET Avios Calculate" id="m-avios" method="GET">
        <con:parameters>
          <con:parameter name="from" default="LHR" style="QUERY"/>
          <con:parameter name="to" default="JFK" style="QUERY"/>
          <con:parameter name="cabin" default="economy" style="QUERY"/>
        </con:parameters>
      </con:method>
    </con:resource>

    <!-- Auth Resources -->
    <con:resource name="Auth Login" path="/auth/login" id="r-auth-login">
      <con:method name="POST Login" id="m-login" method="POST">
        <con:request name="Request 1" mediaType="application/json">
          <con:requestHeaders>
            <con:entry key="Content-Type" value="application/json"/>
          </con:requestHeaders>
        </con:request>
      </con:method>
    </con:resource>

    <con:resource name="Auth Register" path="/auth/register" id="r-auth-register">
      <con:method name="POST Register" id="m-register" method="POST">
        <con:request name="Request 1" mediaType="application/json">
          <con:requestHeaders>
            <con:entry key="Content-Type" value="application/json"/>
          </con:requestHeaders>
        </con:request>
      </con:method>
    </con:resource>

    <!-- Offers Resource -->
    <con:resource name="Offers" path="/offers" id="r-offers">
      <con:method name="GET Offers" id="m-offers" method="GET"/>
    </con:resource>

  </con:interface>

  <!-- ═══════════════════════════════════════════
       TEST SUITE 1 — INFRASTRUCTURE
       ═══════════════════════════════════════════ -->
  <con:testSuite name="1 - Infrastructure" id="ts-infra">

    <!-- TC 1.1 Health Check -->
    <con:testCase name="TC1.1 Health Check" id="tc-health">
      <con:testStep type="restrequest" name="GET /health" id="ts-health-req">
        <con:config resourcePath="/health" methodName="GET Health"
          service="BA Backend API">
          <con:restRequest name="GET /health" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/health</con:resource>
            <con:method>GET</con:method>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Health Response" id="ts-health-assert">
        <con:config>
          <con:script>
def response = testRunner.testCase.testSteps["GET /health"].testRequest.response
def json = new groovy.json.JsonSlurper().parseText(response.responseContent)
assert response.statusCode == 200, "Expected 200, got ${response.statusCode}"
assert json.status == "ok", "Expected status=ok, got ${json.status}"
assert json.service == "ba-backend", "Expected service=ba-backend"
assert json.timestamp != null, "Missing timestamp"
log.info "Health check PASSED: status=${json.status}"
          </con:script>
        </con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 1.2 Airport Search - London -->
    <con:testCase name="TC1.2 Airport Search London" id="tc-airports-london">
      <con:testStep type="restrequest" name="GET /airports?q=london" id="ts-airports-london">
        <con:config resourcePath="/airports" methodName="GET Airports"
          service="BA Backend API">
          <con:restRequest name="GET airports london" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/airports</con:resource>
            <con:method>GET</con:method>
            <con:parameters>
              <con:entry key="q" value="london"/>
            </con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Airports" id="ts-airports-assert">
        <con:config>
          <con:script>
def response = testRunner.testCase.testSteps["GET /airports?q=london"].testRequest.response
def json = new groovy.json.JsonSlurper().parseText(response.responseContent)
assert response.statusCode == 200, "Expected 200, got ${response.statusCode}"
assert json.success == true, "Expected success=true"
assert json.data.size() > 0, "Expected at least 1 airport"
def lhr = json.data.find { it.iataCode == "LHR" }
assert lhr != null, "Expected LHR in results"
assert lhr.name.toLowerCase().contains("heathrow"), "Expected Heathrow in name"
log.info "Airport search PASSED: found ${json.data.size()} airports, LHR found"
          </con:script>
        </con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 1.3 Airport Search - Dubai -->
    <con:testCase name="TC1.3 Airport Search Dubai" id="tc-airports-dubai">
      <con:testStep type="restrequest" name="GET /airports?q=dubai" id="ts-airports-dubai">
        <con:config resourcePath="/airports" methodName="GET Airports"
          service="BA Backend API">
          <con:restRequest name="GET airports dubai" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/airports</con:resource>
            <con:method>GET</con:method>
            <con:parameters>
              <con:entry key="q" value="dubai"/>
            </con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Dubai Airport" id="ts-dubai-assert">
        <con:config>
          <con:script>
def response = testRunner.testCase.testSteps["GET /airports?q=dubai"].testRequest.response
def json = new groovy.json.JsonSlurper().parseText(response.responseContent)
assert response.statusCode == 200
assert json.data.find { it.iataCode == "DXB" } != null, "Expected DXB"
log.info "Dubai airport search PASSED"
          </con:script>
        </con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 1.4 Destinations -->
    <con:testCase name="TC1.4 Get All Destinations" id="tc-destinations">
      <con:testStep type="restrequest" name="GET /destinations" id="ts-destinations">
        <con:config resourcePath="/destinations" methodName="GET Destinations"
          service="BA Backend API">
          <con:restRequest name="GET destinations" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/destinations</con:resource>
            <con:method>GET</con:method>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Destinations" id="ts-dest-assert">
        <con:config>
          <con:script>
def response = testRunner.testCase.testSteps["GET /destinations"].testRequest.response
def json = new groovy.json.JsonSlurper().parseText(response.responseContent)
assert response.statusCode == 200
assert json.success == true
assert json.data.size() >= 6, "Expected at least 6 destinations, got ${json.data.size()}"
def cities = json.data.collect { it.city }
assert cities.contains("New York"), "Expected New York"
assert cities.contains("Dubai"), "Expected Dubai"
log.info "Destinations PASSED: ${json.data.size()} destinations: ${cities.join(', ')}"
          </con:script>
        </con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 1.5 Offers -->
    <con:testCase name="TC1.5 Get Offers" id="tc-offers">
      <con:testStep type="restrequest" name="GET /offers" id="ts-offers">
        <con:config resourcePath="/offers" methodName="GET Offers"
          service="BA Backend API">
          <con:restRequest name="GET offers" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/offers</con:resource>
            <con:method>GET</con:method>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Offers" id="ts-offers-assert">
        <con:config>
          <con:script>
def response = testRunner.testCase.testSteps["GET /offers"].testRequest.response
def json = new groovy.json.JsonSlurper().parseText(response.responseContent)
assert response.statusCode == 200
assert json.success == true
log.info "Offers PASSED: ${json.data?.size()} offers returned"
          </con:script>
        </con:config>
      </con:testStep>
    </con:testCase>

  </con:testSuite>

  <!-- ═══════════════════════════════════════════
       TEST SUITE 2 — FLIGHT SEARCH
       ═══════════════════════════════════════════ -->
  <con:testSuite name="2 - Flight Search" id="ts-flights">

    <!-- TC 2.1 LHR to JFK Business -->
    <con:testCase name="TC2.1 Search LHR-JFK Business Dec" id="tc-flights-jfk">
      <con:testStep type="restrequest" name="GET flights LHR-JFK" id="ts-flights-jfk">
        <con:config service="BA Backend API">
          <con:restRequest name="LHR to JFK" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/search</con:resource>
            <con:method>GET</con:method>
            <con:parameters>
              <con:entry key="from" value="LHR"/>
              <con:entry key="to" value="JFK"/>
              <con:entry key="departureDate" value="2026-12-20"/>
              <con:entry key="adults" value="1"/>
              <con:entry key="cabin" value="BUSINESS"/>
            </con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Flights JFK" id="ts-assert-jfk">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET flights LHR-JFK"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
assert j.success == true
assert j.data.flights.size() == 6, "Expected 6 flights, got ${j.data.flights.size()}"
def f = j.data.flights[0]
assert f.flightNumber != null
assert f.from == "LHR"
assert f.to == "JFK"
assert f.price.grandTotal.toDouble() > 0
log.info "LHR-JFK PASSED: ${j.data.flights.size()} flights, first=${f.flightNumber} GBP${f.price.grandTotal}"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 2.2 LHR to DXB Economy -->
    <con:testCase name="TC2.2 Search LHR-DXB Economy" id="tc-flights-dxb">
      <con:testStep type="restrequest" name="GET flights LHR-DXB" id="ts-flights-dxb">
        <con:config service="BA Backend API">
          <con:restRequest name="LHR to DXB" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/search</con:resource>
            <con:method>GET</con:method>
            <con:parameters>
              <con:entry key="from" value="LHR"/>
              <con:entry key="to" value="DXB"/>
              <con:entry key="departureDate" value="2026-10-18"/>
              <con:entry key="adults" value="2"/>
              <con:entry key="cabin" value="ECONOMY"/>
            </con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Flights DXB" id="ts-assert-dxb">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET flights LHR-DXB"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
assert j.data.flights.size() == 6
assert j.data.flights[0].to == "DXB"
log.info "LHR-DXB PASSED: ${j.data.flights.size()} flights"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 2.3 LHR to BCN Economy -->
    <con:testCase name="TC2.3 Search LHR-BCN Economy" id="tc-flights-bcn">
      <con:testStep type="restrequest" name="GET flights LHR-BCN" id="ts-flights-bcn">
        <con:config service="BA Backend API">
          <con:restRequest name="LHR to BCN" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/search</con:resource>
            <con:method>GET</con:method>
            <con:parameters>
              <con:entry key="from" value="LHR"/>
              <con:entry key="to" value="BCN"/>
              <con:entry key="departureDate" value="2026-07-20"/>
              <con:entry key="adults" value="1"/>
              <con:entry key="cabin" value="ECONOMY"/>
            </con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert BCN Flights" id="ts-assert-bcn">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET flights LHR-BCN"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
assert j.data.flights.size() == 6
assert j.data.flights[0].price.grandTotal.toDouble() < 200, "BCN economy should be under GBP200"
log.info "LHR-BCN PASSED: cheapest GBP${j.data.flights.collect{it.price.grandTotal.toDouble()}.min()}"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

    <!-- TC 2.4 Missing required param returns 400 -->
    <con:testCase name="TC2.4 Missing Param Returns Error" id="tc-flights-missing">
      <con:testStep type="restrequest" name="GET flights no params" id="ts-flights-empty">
        <con:config service="BA Backend API">
          <con:restRequest name="No Params" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/search</con:resource>
            <con:method>GET</con:method>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Error Response" id="ts-assert-missing">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET flights no params"].testRequest.response
assert r.statusCode == 400 || r.statusCode == 422, "Expected 4xx for missing params, got ${r.statusCode}"
log.info "Missing param validation PASSED: got ${r.statusCode}"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

  </con:testSuite>

  <!-- ═══════════════════════════════════════════
       TEST SUITE 3 — FLIGHT STATUS
       ═══════════════════════════════════════════ -->
  <con:testSuite name="3 - Flight Status" id="ts-status">

    <con:testCase name="TC3.1 Status BA117 On Time" id="tc-status-ba117">
      <con:testStep type="restrequest" name="GET status BA117" id="ts-status-ba117">
        <con:config service="BA Backend API">
          <con:restRequest name="Status BA117" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/status</con:resource>
            <con:method>GET</con:method>
            <con:parameters><con:entry key="flightNumber" value="BA117"/></con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert BA117" id="ts-assert-ba117">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET status BA117"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
assert j.success == true
def s = j.data[0]
assert s.flightNumber == "BA117"
assert s.statusLabel != null
assert s.gate != null
assert s.terminal != null
assert s.progress >= 0 &amp;&amp; s.progress &lt;= 100
log.info "BA117 PASSED: ${s.statusLabel} Gate=${s.gate} Progress=${s.progress}%"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC3.2 Status BA204 Delayed" id="tc-status-ba204">
      <con:testStep type="restrequest" name="GET status BA204" id="ts-status-ba204">
        <con:config service="BA Backend API">
          <con:restRequest name="Status BA204" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/status</con:resource>
            <con:method>GET</con:method>
            <con:parameters><con:entry key="flightNumber" value="BA204"/></con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert BA204" id="ts-assert-ba204">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET status BA204"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
assert j.data[0].flightNumber == "BA204"
assert j.data[0].status == "delayed"
log.info "BA204 PASSED: ${j.data[0].statusLabel}"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC3.3 Status by Route LHR-JFK" id="tc-status-route">
      <con:testStep type="restrequest" name="GET status by route" id="ts-status-route">
        <con:config service="BA Backend API">
          <con:restRequest name="Status by route" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/status</con:resource>
            <con:method>GET</con:method>
            <con:parameters>
              <con:entry key="from" value="LHR"/>
              <con:entry key="to" value="JFK"/>
              <con:entry key="date" value="2026-12-20"/>
            </con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Route Status" id="ts-assert-route">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET status by route"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
assert j.data.size() > 0, "Expected results for LHR-JFK route"
log.info "Route status PASSED: ${j.data.size()} flights"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC3.4 Invalid Flight Number Returns Unknown" id="tc-status-invalid">
      <con:testStep type="restrequest" name="GET status INVALID" id="ts-status-invalid">
        <con:config service="BA Backend API">
          <con:restRequest name="Invalid flight" mediaType="application/json">
            <con:endpoint>https://first-eight-cyan.vercel.app</con:endpoint>
            <con:resource>/api/flights/status</con:resource>
            <con:method>GET</con:method>
            <con:parameters><con:entry key="flightNumber" value="BA999"/></con:parameters>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="groovy" name="Assert Unknown Flight" id="ts-assert-invalid">
        <con:config><con:script>
def r = testRunner.testCase.testSteps["GET status INVALID"].testRequest.response
def j = new groovy.json.JsonSlurper().parseText(r.responseContent)
assert r.statusCode == 200
def s = j.data[0]
assert s != null
assert s.flightNumber == "BA999"
log.info "Unknown flight PASSED: returned ${s.status} status"
        </con:script></con:config>
      </con:testStep>
    </con:testCase>

  </con:testSuite>

  <!-- ═══════════════════════════════════════════
       TEST SUITE 4 — BOOKING LIFECYCLE
       ═══════════════════════════════════════════ -->
