      </con:testStep>
    </con:testCase>

    <con:testCase name="TC3.4 BA011 Now Boarding" failOnError="true">
      <con:testStep type="httprequest" name="GET Status BA011">
        <con:config>
          <con:request name="GET Status BA011"
            URL="${#Project#BASE_URL}/flights/status?flightNumber=BA011"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
