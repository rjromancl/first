<?xml version="1.0" encoding="UTF-8"?>
<con:soapui-project
  xmlns:con="http://eviware.com/soapui/config"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  name="British Airways API Test Suite"
  activeEnvironment="Default"
  soapui-version="5.7.2">

  <con:properties>
    <con:property><con:name>BASE_URL</con:name><con:value>https://first-eight-cyan.vercel.app/api</con:value></con:property>
    <con:property><con:name>BOOKING_REF</con:name><con:value>XYMBA1</con:value></con:property>
    <con:property><con:name>BOOKING_SURNAME</con:name><con:value>Wilson</con:value></con:property>
    <con:property><con:name>AUTH_TOKEN</con:name><con:value></con:value></con:property>
  </con:properties>


  <!-- ====================================================
       TEST SUITE 1: INFRASTRUCTURE
       ==================================================== -->
  <con:testSuite name="1 - Infrastructure">
    <con:properties/>

    <con:testCase name="TC1.1 Health Check" failOnError="true">
      <con:testStep type="httprequest" name="GET Health">
        <con:config>
          <con:request name="GET Health" URL="${#Project#BASE_URL}/health" method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Status is ok">
              <con:configuration>
                <con:expression>$.status</con:expression>
                <con:expectedContent>ok</con:expectedContent>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Exists" name="Timestamp exists">
              <con:configuration><con:expression>$.timestamp</con:expression></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC1.2 Airport Search London" failOnError="true">
      <con:testStep type="httprequest" name="GET Airports London">
        <con:config>
          <con:request name="GET Airports London" URL="${#Project#BASE_URL}/airports?q=london" method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Success true">
              <con:configuration>
                <con:expression>$.success</con:expression>
                <con:expectedContent>true</con:expectedContent>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Count" name="At least 1 airport">
              <con:configuration>
                <con:expression>$.data[*]</con:expression>
                <con:expectedContent>1</con:expectedContent>
                <con:allowWildcards>true</con:allowWildcards>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="LHR code returned">
              <con:configuration>
                <con:expression>$.data[0].iataCode</con:expression>
                <con:expectedContent>LHR</con:expectedContent>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC1.3 Airport Search Dubai" failOnError="true">
      <con:testStep type="httprequest" name="GET Airports Dubai">
        <con:config>
          <con:request name="GET Airports Dubai" URL="${#Project#BASE_URL}/airports?q=dubai" method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="DXB returned">
              <con:configuration>
                <con:expression>$.data[0].iataCode</con:expression>
                <con:expectedContent>DXB</con:expectedContent>
              </con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC1.4 Get All Destinations" failOnError="true">
      <con:testStep type="httprequest" name="GET Destinations">
        <con:config>
          <con:request name="GET Destinations" URL="${#Project#BASE_URL}/destinations" method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Success true">
              <con:configuration>
                <con:expression>$.success</con:expression>
                <con:expectedContent>true</con:expectedContent>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Exists" name="Data array exists">
              <con:configuration><con:expression>$.data[0]</con:expression></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC1.5 Airport Search Short Query Returns 400" failOnError="false">
      <con:testStep type="httprequest" name="GET Airports Short Query">
        <con:config>
          <con:request name="GET Airports Short" URL="${#Project#BASE_URL}/airports?q=l" method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 400">
              <con:configuration><con:codes>400</con:codes></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

  </con:testSuite>

  <!-- ====================================================
       TEST SUITE 2: FLIGHT SEARCH
       ==================================================== -->
  <con:testSuite name="2 - Flight Search">
    <con:properties/>

    <con:testCase name="TC2.1 Search LHR to JFK Business" failOnError="true">
      <con:testStep type="httprequest" name="GET Flights LHR-JFK">
        <con:config>
          <con:request name="GET Flights LHR-JFK"
            URL="${#Project#BASE_URL}/flights/search?from=LHR&amp;to=JFK&amp;departureDate=2026-12-20&amp;adults=1&amp;cabin=BUSINESS"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Success true">
              <con:configuration><con:expression>$.success</con:expression><con:expectedContent>true</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Exists" name="Flights array exists">
              <con:configuration><con:expression>$.data.flights[0]</con:expression></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Origin is LHR">
              <con:configuration><con:expression>$.data.flights[0].from</con:expression><con:expectedContent>LHR</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Destination is JFK">
              <con:configuration><con:expression>$.data.flights[0].to</con:expression><con:expectedContent>JFK</con:expectedContent></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC2.2 Search LHR to DXB Economy" failOnError="true">
      <con:testStep type="httprequest" name="GET Flights LHR-DXB">
        <con:config>
          <con:request name="GET Flights LHR-DXB"
            URL="${#Project#BASE_URL}/flights/search?from=LHR&amp;to=DXB&amp;departureDate=2026-10-18&amp;adults=2&amp;cabin=ECONOMY"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Destination is DXB">
              <con:configuration><con:expression>$.data.flights[0].to</con:expression><con:expectedContent>DXB</con:expectedContent></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Exists" name="Price exists">
              <con:configuration><con:expression>$.data.flights[0].price.grandTotal</con:expression></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC2.3 Search LHR to BCN Economy" failOnError="true">
      <con:testStep type="httprequest" name="GET Flights LHR-BCN">
        <con:config>
          <con:request name="GET Flights LHR-BCN"
            URL="${#Project#BASE_URL}/flights/search?from=LHR&amp;to=BCN&amp;departureDate=2026-07-20&amp;adults=1&amp;cabin=ECONOMY"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Destination is BCN">
              <con:configuration><con:expression>$.data.flights[0].to</con:expression><con:expectedContent>BCN</con:expectedContent></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC2.4 Search LHR to NRT Business" failOnError="true">
      <con:testStep type="httprequest" name="GET Flights LHR-NRT">
        <con:config>
          <con:request name="GET Flights LHR-NRT"
            URL="${#Project#BASE_URL}/flights/search?from=LHR&amp;to=NRT&amp;departureDate=2026-08-01&amp;adults=1&amp;cabin=BUSINESS"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 200">
              <con:configuration><con:codes>200</con:codes></con:configuration>
            </con:assertion>
            <con:assertion type="JSONPath Match" name="Destination is NRT">
              <con:configuration><con:expression>$.data.flights[0].to</con:expression><con:expectedContent>NRT</con:expectedContent></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

    <con:testCase name="TC2.5 Missing Departure Date Returns 400" failOnError="false">
      <con:testStep type="httprequest" name="GET Flights No Date">
        <con:config>
          <con:request name="GET Flights No Date"
            URL="${#Project#BASE_URL}/flights/search?from=LHR&amp;to=JFK"
            method="GET" mediaType="application/json">
            <con:assertion type="Valid HTTP Status Codes" name="Status 400">
              <con:configuration><con:codes>400</con:codes></con:configuration>
            </con:assertion>
          </con:request>
        </con:config>
      </con:testStep>
    </con:testCase>

  </con:testSuite>

  <!-- ====================================================
       TEST SUITE 3: FLIGHT STATUS
       ==================================================== -->
  <con:testSuite name="3 - Flight Status">
