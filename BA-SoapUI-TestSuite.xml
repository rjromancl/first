        <con:config><con:script>
import groovyx.net.http.RESTClient
import groovy.json.JsonOutput
def base = "https://first-eight-cyan.vercel.app/api"
def flightJson = testRunner.testCase.getPropertyValue("FLIGHT_OBJ")
def flight = new groovy.json.JsonSlurper().parseText(flightJson)
def http = new RESTClient(base)
def payload = [flightOffer: flight, travelers: [[firstName:"Priya", lastName:"Sharma", phone:"07800123456", nationality:"IN"]], contacts: []]
def resp = http.post(path: "/bookings", body: JsonOutput.toJson(payload), requestContentType: "application/json")
assert resp.status == 200 || resp.status == 201
def ref = resp.data.data.reference
assert ref != null &amp;&amp; ref.length() == 6
testRunner.testCase.setPropertyValue("E2E_REF", ref)
log.info "E2E Step2 PASSED: Booking ${ref} confirmed GBP${resp.data.data.totalPaid}"
        </con:script></con:config>
      </con:testStep>

